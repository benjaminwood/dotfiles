{{- if .is_docker -}}
#!/bin/bash
set -euo pipefail

# Ensure Claude Code is installed for the current user under ~/.local/bin.
# That's where Anthropic's installer puts it, and where `claude upgrade`
# writes new versions. Previously this script ALSO published a copy to
# /usr/local/bin/claude — a static snapshot — to work around symlink
# traversal failures when other users tried to exec a claude binary nested
# inside ben's 0700 home. We've moved off that model: in the eldar
# container each user (ben, eldar) has their own ~/.local/share/claude tree
# under a 0750-group-ben home, so any in-container user can exec their own
# copy. The system-wide snapshot was just shadowing the user-local install
# and silently keeping `claude upgrade` from taking effect. So we don't
# create it anymore.

if [ -x "$HOME/.local/bin/claude" ]; then
  exit 0
fi

# If a previously-downloaded binary exists under ~/.claude/downloads/, link
# it in. Otherwise, run the upstream installer.
if compgen -G "$HOME/.claude/downloads/claude-*" > /dev/null; then
  local_bin="$(ls -1 "$HOME/.claude/downloads/"claude-* | head -1)"
  mkdir -p "$HOME/.local/bin"
  ln -sf "$local_bin" "$HOME/.local/bin/claude"
  exit 0
fi

echo "Installing Claude Code..."
if ! curl -fsSL https://claude.ai/install.sh | bash; then
  echo "Warning: Claude Code installation failed (possibly rate-limited). Skipping." >&2
fi
{{- end }}
