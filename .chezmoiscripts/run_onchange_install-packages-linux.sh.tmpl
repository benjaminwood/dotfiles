{{- if and (eq .chezmoi.os "linux") .is_docker -}}
#!/bin/bash
set -euo pipefail

sudo() { if [ "$(id -u)" -eq 0 ]; then "$@"; else command sudo "$@"; fi; }

echo "Installing system packages..."
if command -v apt-get &>/dev/null; then
  sudo apt-get update -qq
  sudo apt-get install -o Dpkg::Options::="--force-confold" -yq git locales netcat-openbsd zsh iproute2 tmux
  sudo apt-get clean -y
  sudo rm -rf /var/lib/apt/lists/*
elif command -v apk &>/dev/null; then
  sudo apk add --no-cache git tmux zsh iproute2 ncurses
elif command -v yum &>/dev/null; then
  sudo yum -y install git zsh tmux iproute2
elif command -v dnf &>/dev/null; then
  sudo dnf -y install git zsh tmux iproute
fi

# Locale generation (Debian/Ubuntu only)
if command -v locale-gen &>/dev/null; then
  echo "Generating en_US.UTF-8 locale..."
  sudo sed -i 's/# en_US.UTF-8 UTF-8/en_US.UTF-8 UTF-8/' /etc/locale.gen
  sudo locale-gen en_US.UTF-8
  sudo update-locale LANG=en_US.UTF-8
fi

echo "Setting system-wide environment..."
printf 'LANG=en_US.UTF-8\nTERM=xterm-256color\n' | sudo tee /etc/environment > /dev/null

# Install GitHub CLI from the upstream release tarball. Avoids per-distro
# repo setup and works the same way on apt/apk/yum/dnf hosts. Update
# GH_VERSION manually when a new version is desired.
if ! command -v gh &>/dev/null; then
  GH_VERSION="2.60.0"
  GH_ARCH="$(uname -m)"
  case "$GH_ARCH" in
    x86_64)        GH_ARCH="amd64" ;;
    aarch64|arm64) GH_ARCH="arm64" ;;
    *)             echo "Skipping gh install: unsupported arch $GH_ARCH"; GH_ARCH="" ;;
  esac
  if [ -n "$GH_ARCH" ]; then
    echo "Installing gh $GH_VERSION ($GH_ARCH)..."
    curl -fsSL "https://github.com/cli/cli/releases/download/v${GH_VERSION}/gh_${GH_VERSION}_linux_${GH_ARCH}.tar.gz" \
      | sudo tar -xz -C /usr/local --strip-components=1 --no-same-owner
  fi
fi
{{- end }}
